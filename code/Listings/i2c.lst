   1          #include "i2c.h"
   2          //延迟函数   
   3          void Delay5us()
   4          {
   5   1          unsigned char n = 4;
   6   1      
   7   1          while (n--)
   8   1          {
   9   2              _nop_();
  10   2              _nop_();
  11   2          }
  12   1      }
  13          
  14          //I2C开始
  15          void I2C_Start()
  16          {
  17   1          SDA = 1;                    //拉高数据线
  18   1          SCL = 1;                    //拉高时钟线
  19   1          Delay5us();                 //延时
  20   1          SDA = 0;                    //产生下降沿
  21   1          Delay5us();                 //延时
  22   1          SCL = 0;                    //拉低时钟线
  23   1      }
  24          
  25          //I2C停止
  26          void I2C_Stop()
  27          {
  28   1          SDA = 0;                    //拉低数据线
  29   1          SCL = 1;                    //拉高时钟线
  30   1          Delay5us();                 //延时
  31   1          SDA = 1;                    //产生上升沿
  32   1          Delay5us();                 //延时
  33   1      }
  34          
  35          //I2C发送应答信号
  36          void I2C_SendACK(bit ack)
  37          {
  38   1          SDA = ack;                  //写应答信号
  39   1          SCL = 1;                    //拉高时钟线
  40   1          Delay5us();                 //延时
  41   1          SCL = 0;                    //拉低时钟线
  42   1          Delay5us();                 //延时
  43   1      }
  44          
  45          //I2C接收应答信号
  46          bit I2C_RecvACK()
  47          {
  48   1          SCL = 1;                    //拉高时钟线
  49   1          Delay5us();                 //延时
  50   1          CY = SDA;                   //读应答信号
  51   1          SCL = 0;                    //拉低时钟线
  52   1          Delay5us();                 //延时
  53   1          return CY;
  54   1      }
