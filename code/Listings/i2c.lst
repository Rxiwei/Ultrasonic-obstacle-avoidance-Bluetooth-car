 120          /***************************************************************
 121          ** 函数名称: Single_ReadI2C
 122          ** 功能描述: 从I2C设备读取一个字节数据
 123          ** 输　入:   
 124          ** 输　出:   
 125          ** 全局变量: 
 126          ***************************************************************/
 127          unsigned char Single_ReadI2C(unsigned char REG_Address)
 128          {
 129   1        unsigned char REG_data;
 130   1        I2C_Start();                   //起始信号
 131   1        I2C_SendByte(SlaveAddress);    //发送设备地址+写信号
 132   1        I2C_SendByte(REG_Address);     //发送存储单元地址，从0开始  
 133   1        I2C_Start();                   //起始信号
 134   1        I2C_SendByte(SlaveAddress+1);  //发送设备地址+读信号
 135   1        REG_data=I2C_RecvByte();       //读出寄存器数据
 136   1        I2C_SendACK(1);                //接收应答信号
 137   1        I2C_Stop();                    //停止信号
 138   1        return REG_data;
 139   1      }
