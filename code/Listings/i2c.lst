  56          /***************************************************************
  57          ** 函数名称: I2C_SendByte
  58          ** 功能描述: 向I2C总线发送一个字节数据
  59          ** 输　入:   
  60          ** 输　出:   
  61          ** 全局变量: 
  62          ***************************************************************/
  63          void I2C_SendByte(unsigned char dat)
  64          {
  65   1          unsigned char i;
  66   1          for (i=0; i<8; i++)         //8位计数器
  67   1          {
  68   2              dat <<= 1;              //移出数据的最高位
  69   2              SDA = CY;               //送数据口
  70   2              SCL = 1;                //拉高时钟线
  71   2              Delay5us();             //延时
  72   2              SCL = 0;                //拉低时钟线
  73   2              Delay5us();             //延时
  74   2          }
  75   1          I2C_RecvACK();
  76   1      }
  77          
  78          /***************************************************************
  79          ** 函数名称: I2C_RecvByte
  80          ** 功能描述: 从I2C总线接收一个字节数据
  81          ** 输　入:   
  82          ** 输　出:   
  83          ** 全局变量: 
  84          ***************************************************************/
  85          unsigned char I2C_RecvByte()
  86          {
  87   1          unsigned i;
  88   1          unsigned char dat = 0;
  89   1          SDA = 1;                    //使能内部上拉,准备读取数据,
  90   1          for (i=0; i<8; i++)         //8位计数器
  91   1          {
  92   2              dat <<= 1;
  93   2              SCL = 1;                //拉高时钟线
  94   2              Delay5us();             //延时
  95   2              dat |= SDA;             //读数据               
  96   2              SCL = 0;                //拉低时钟线
  97   2              Delay5us();             //延时
  98   2          }
  99   1          return dat;
 100   1      }
